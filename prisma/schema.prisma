// Axis & Allies Anniversary Edition companion — data model.
// Enums are stored as plain strings (SQLite has no native enums); values are
// validated in the app layer against src/lib/anniversary.config.ts. This keeps
// the schema portable to Postgres later without a migration rewrite.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id              String   @id @default(cuid())
  name            String
  opponent        String?
  // Default perspective coalition when no player is selected: "AXIS" | "ALLIES".
  // Legacy field; per-player perspective now comes from the Player model.
  side            String
  // "Y1941" (Barbarossa start) | "Y1942" (high-water mark)
  scenario        String   @default("Y1942")
  // "FAST" | "DETAILED"
  trackingMode    String   @default("DETAILED")
  // Victory-city tokens needed to win: 13 (short) | 15 (standard) | 18 (full)
  victoryCityGoal Int      @default(15)
  // Whether this game uses Research & Development. When false, the R&D
  // breakthrough columns are hidden from the Production board.
  includeResearch Boolean  @default(true)
  // How combat moves flow into battles, chosen at setup:
  // "DECLARE_THEN_FIGHT" (declare every combat move, then fight all battles) |
  // "FIGHT_EACH" (resolve each declared move straight into its battle).
  combatResolution String  @default("DECLARE_THEN_FIGHT")
  // "ACTIVE" | "VICTORY" | "DEFEAT"
  status          String   @default("ACTIVE")

  // ── Turn engine pointer ───────────────────────────────────────────────
  // Whose power-turn is live, and which of the 7 phases they are in.
  // Turn order is ASSIGNABLE_POWERS (USSR → GERMANY → UK → ITALY → JAPAN → USA);
  // China folds into the USA turn. Phase numbers map to PHASES in lib/turn.ts
  // (1 R&D · 2 Purchase · 3 Combat Move · 4 Conduct Combat · 5 Noncombat ·
  // 6 Mobilize · 7 Collect Income). Phase 1 is skipped unless includeResearch.
  activePowerKey  String   @default("USSR")
  activePhase     Int      @default(2)

  startDate       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rounds      Round[]
  players     Player[]
  assignments PowerAssignment[]
  nationStates NationState[]
  combatMoves CombatMoveOrder[]
  movements   Movement[]
  breakthroughs Breakthrough[]
}

// R&D breakthroughs a power has unlocked (Phase 1). One row per tech so the
// app remembers chart state between sessions — a tracking pain the physical
// game leaves to players.
model Breakthrough {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  nation      String
  techKey     String // key into RESEARCH_TECHS in lib/research.ts
  roundNumber Int
  createdAt   DateTime @default(now())

  @@unique([campaignId, nation, techKey])
  @@index([campaignId])
}

// Live, cross-round state for a power: its IPC treasury and unit inventory.
// Distinct from NationEntry (a per-round ledger snapshot used for analytics) —
// NationState is the authoritative "what does this nation have right now."
// Designed to extend to a full board model later: UnitStock.territory and
// future Territory rows can be added without reshaping this table.
model NationState {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  nation     String
  ipc        Int      @default(0) // running treasury (IPC certificates on hand)
  updatedAt  DateTime @updatedAt

  stocks  UnitStock[]
  pending PendingUnit[]

  @@unique([campaignId, nation])
  @@index([campaignId])
}

// A quantity of one unit type a nation currently owns (mobilized / on the board).
// `territory` is reserved for the future map model; null = a single national pool.
model UnitStock {
  id            String      @id @default(cuid())
  nationState   NationState @relation(fields: [nationStateId], references: [id], onDelete: Cascade)
  nationStateId String
  unitType      String      // key into UNITS in anniversary.config.ts
  quantity      Int         @default(0)

  @@unique([nationStateId, unitType])
  @@index([nationStateId])
}

// A declared attack from Phase 3 (Combat Move). The active power commits an
// attacking stack against a target; Phase 4 (Conduct Combat) resolves each one
// on the shared Battle page, which seeds from this order and marks it RESOLVED.
// `units` is a Stack ({ unitType: quantity }) — JSON keeps it position-agnostic
// until the board model lands.
model CombatMoveOrder {
  id             String   @id @default(cuid())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId     String
  roundNumber    Int
  attackerNation String
  defenderNation String
  territory      String?
  territoryIpc   Int      @default(0)
  units          Json     // Stack: { [unitType]: quantity }
  amphibious     Boolean  @default(false)
  // "PENDING" | "RESOLVED"
  status         String   @default("PENDING")
  resultStatus   String? // battle engine status when resolved
  createdAt      DateTime @default(now())

  @@index([campaignId, roundNumber])
}

// A Phase 5 (Noncombat Move) reposition: units a power shifts between
// territories without fighting. Trust-and-record — a turn log that does not yet
// affect inventory (single national pool) but seeds the future board model.
model Movement {
  id            String   @id @default(cuid())
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId    String
  roundNumber   Int
  nation        String
  fromTerritory String?
  toTerritory   String?
  units         Json     // Stack: { [unitType]: quantity }
  createdAt     DateTime @default(now())

  @@index([campaignId, roundNumber])
}

// Units purchased in Phase 2 but not yet placed. Phase 6 (Mobilize) moves these
// into UnitStock. IPC is deducted at purchase time, so this is just a holding pen.
model PendingUnit {
  id            String      @id @default(cuid())
  nationState   NationState @relation(fields: [nationStateId], references: [id], onDelete: Cascade)
  nationStateId String
  unitType      String
  quantity      Int         @default(0)

  @@index([nationStateId])
}

model Player {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  assignments PowerAssignment[]

  @@index([campaignId])
}

// One row per controlled power. Each power is assigned to exactly one player
// within a campaign (enforced by the unique constraint). China is implicitly
// controlled by whoever holds the USA — it is not stored as its own assignment.
model PowerAssignment {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId   String
  powerKey   String

  @@unique([campaignId, powerKey])
  @@index([campaignId])
  @@index([playerId])
}

model Round {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  number     Int
  notes      String?
  createdAt  DateTime @default(now())

  // Optional per-round board snapshot (mirrors the TurnLedger SITREP panel).
  // Region control as owned/total counts; victory cities held by each side.
  tcEuropeOwned   Int?
  tcEuropeTotal   Int?
  tcAsiaOwned     Int?
  tcAsiaTotal     Int?
  tcAmericasOwned Int?
  tcAmericasTotal Int?
  vcAxis          Int?
  vcAllies        Int?

  entries NationEntry[]

  @@unique([campaignId, number])
  @@index([campaignId])
}

model NationEntry {
  id      String @id @default(cuid())
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId String
  // "GERMANY" | "JAPAN" | "ITALY" | "USSR" | "UK" | "USA" | "CHINA"
  nation  String

  income          Int @default(0) // IPCs collected this turn (territory income)
  objectiveBonus  Int @default(0) // National Objective bonus IPCs (Anniversary)
  purchases       Int @default(0) // IPCs spent on units
  ipcRemaining    Int @default(0) // IPCs banked at end of turn
  attackPower     Int @default(0) // total attack power (entered, or computed in DETAILED mode)
  ipcLost         Int @default(0) // FAST mode: total IPC value of units lost (DETAILED uses itemized losses)

  losses Loss[]
  raids  BomberRaid[]

  @@unique([roundId, nation])
  @@index([roundId])
}

model Loss {
  id            String      @id @default(cuid())
  nationEntry   NationEntry @relation(fields: [nationEntryId], references: [id], onDelete: Cascade)
  nationEntryId String
  unitType      String // key into UNITS in anniversary.config.ts
  quantity      Int     @default(0)

  @@index([nationEntryId])
}

model BomberRaid {
  id            String      @id @default(cuid())
  nationEntry   NationEntry @relation(fields: [nationEntryId], references: [id], onDelete: Cascade)
  nationEntryId String
  bombers       Int         @default(1)
  damage        Int         @default(0) // IPC damage inflicted on the factory
  bombersLost   Int         @default(0)

  @@index([nationEntryId])
}
