# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# @3d-dice/dice-box postinstall artifacts (duplicates of the committed
# public/assets/dice-box/ assets; regenerated on every npm install)
/public/assets/ammo/
/public/assets/themes/

# production
/build

# misc
.DS_Store
*.pem

# local database (SQLite dev artifacts — never commit data)
/dev.db
*.db
*.db-journal

# Docker-free local Postgres data (PGlite — see scripts/pg-dev.mjs)
/.pgdata/

# local hidden dev-server log
/dev-server.log

# development screenshots at the project root (not needed in the repo)
/*.png

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
